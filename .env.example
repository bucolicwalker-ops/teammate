# 复制本文件为 .env 再填（.env 不会被提交，已在 .gitignore）
OPENAI_API_KEY=
# 按目标公司选一家（都兼容 OpenAI 接口）：
#   阿里通义：https://dashscope.aliyuncs.com/compatible-mode/v1   模型 qwen-plus
#   字节豆包：https://ark.cn-beijing.volces.com/api/v3            模型 doubao-*
#   腾讯混元：https://api.hunyuan.cloud.tencent.com/v1            模型 hunyuan-*
#   DeepSeek：https://api.deepseek.com                            模型 deepseek-chat
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL=qwen-plus
